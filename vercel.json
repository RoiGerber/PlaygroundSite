{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/share/:path*",
      "destination": "https://d3twd5pvxo75es.cloudfront.net/share/:path*"
    },
    {
      "source": "/s/:path*",
      "destination": "https://d3twd5pvxo75es.cloudfront.net/s/:path*"
    }
  ]
}